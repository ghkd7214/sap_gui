*&---------------------------------------------------------------------*
*& Module SET_APP_TOOLBAR_200 OUTPUT
*&---------------------------------------------------------------------*
*&
*&---------------------------------------------------------------------*
MODULE set_app_toolbar_200 OUTPUT.
  DATA : lt_exclude2 TYPE TABLE OF sy-ucomm,
         ls_exclude2 TYPE sy-ucomm.

  CLEAR : ls_exclude2, lt_exclude2.

  IF gv_mode = 'L'.
    ls_exclude2 = 'SAVE'.
    APPEND ls_exclude2 TO lt_exclude2.
  ENDIF.

  SET PF-STATUS 'S200' EXCLUDING lt_exclude2.
ENDMODULE.
*&---------------------------------------------------------------------*
*& Module SET_INIT OUTPUT
*&---------------------------------------------------------------------*
*&
*&---------------------------------------------------------------------*
MODULE set_init OUTPUT.
  IF gv_mode = 'L'.
    LOOP AT SCREEN.
      screen-input = '0'. " 출력 전용으로 설정
    ENDLOOP.
  ELSEIF gv_mode = 'S'.
    MOVE-CORRESPONDING sbook TO zspou03_survey_info_21.

    zspou03_survey_info_21-customid = zspou03_bookinfo_21-customid.
    zspou03_survey_info_21-custtname = zspou03_bookinfo_21-custname.
  ENDIF.

  MODIFY SCREEN.
ENDMODULE.
