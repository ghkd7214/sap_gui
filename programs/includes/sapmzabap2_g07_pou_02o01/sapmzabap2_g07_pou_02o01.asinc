*& Module GET_DATA_103 OUTPUT
*&---------------------------------------------------------------------*
*&
*&---------------------------------------------------------------------*
MODULE get_data_103 OUTPUT.
  CALL METHOD lcl_pou_03=>get_flight_data
    EXPORTING
      iv_carrid = sbook-carrid
      iv_connid = sbook-connid
      iv_fldate = sbook-fldate
    IMPORTING
      es_flight = zspou03_flight_info_21.
ENDMODULE.