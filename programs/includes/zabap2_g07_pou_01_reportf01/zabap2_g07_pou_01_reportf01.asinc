      too_many_lines                = 3
      OTHERS                        = 4.
  IF sy-subrc <> 0.
*     Implement suitable error handling here
  ENDIF.
ENDFORM.
*&---------------------------------------------------------------------*
*& Form set_fcat2
*&---------------------------------------------------------------------*
*& text
*&---------------------------------------------------------------------*
*& -->  p1        text
*& <--  p2        text
*&---------------------------------------------------------------------*
FORM set_fcat2 .
  DEFINE _add_fcat2.
    CLEAR gs_fcat2.
    gs_fcat2-fieldname = &1. " 필드명
    gs_fcat2-ref_table = &2. " 참조 테이블 (텍스트 자동 가져오기 위함)
    gs_fcat2-ref_field = &3. " 참조 필드
    gs_fcat2-coltext   = &4. " 강제 지정할 컬럼명 (필요시)

    " 특수 설정 (옵션)
    CASE &1.
      WHEN 'LIGHT'.
        " 신호등 아이콘인 경우 (컬럼 헤더 없이 좁게 표현)
        gs_fcat2-col_opt = 'X'.
        gs_fcat2-just    = 'C'. " 가운데 정렬
      WHEN 'LUGGWEIGHT'.
        " 수량 필드와 단위 필드 연결
        gs_fcat2-qfieldname = 'WUNIT'.
      WHEN 'LOCCURAM'.
        " 금액 필드와 통화 필드 연결
        gs_fcat2-cfieldname = 'LOCCURKEY'.
      WHEN 'BTN_TXT'.
        " 버튼 텍스트
      WHEN 'CONNID' OR 'FLDATE' OR 'MENUNUMBER'.
        gs_fcat2-hotspot = 'X'.
    ENDCASE.

    APPEND gs_fcat2 TO gt_fcat2.
  END-OF-DEFINITION.


  _add_fcat2 'LIGHT'       ''        ''            'Status'.

  _add_fcat2 'CARRID'      'SBOOK'   'CARRID'      'Carrier'.
  _add_fcat2 'CARRNAME'    'SCARR'   'CARRNAME'    'Airline'. " SCARR 참조
  _add_fcat2 'CONNID'      'SBOOK'   'CONNID'      'No.'.
  _add_fcat2 'FLDATE'      'SBOOK'   'FLDATE'      'Flight Date'.
  _add_fcat2 'BOOKID'      'SBOOK'   'BOOKID'      'Booking No.'.
  _add_fcat2 'CUSTOMID'    'SBOOK'   'CUSTOMID'    'Cust No.'.
  _add_fcat2 'CUSTTYPE'    'SBOOK'   'CUSTTYPE'    'B/P Cust.'.
  _add_fcat2 'SMOKER'      'SBOOK'   'SMOKER'      'Smoker'.

  _add_fcat2 'LUGGWEIGHT'  'SBOOK'   'LUGGWEIGHT'  'Wt'.
  _add_fcat2 'WUNIT'       'SBOOK'   'WUNIT'       'Unit'.

  _add_fcat2 'CLASS'       'SBOOK'   'CLASS'       ''.

  _add_fcat2 'LOCCURAM'    'SBOOK'   'LOCCURAM'    'Amount'.
  _add_fcat2 'LOCCURKEY'   'SBOOK'   'LOCCURKEY'   'Curr'.

  _add_fcat2 'ORDER_DATE'  'SBOOK'   'ORDER_DATE'  'Booking Date'.
  _add_fcat2 'COUNTER'     'SBOOK'   'COUNTER'     'SalesOff'.
  _add_fcat2 'AGENCYNUM'   'SBOOK'   'AGENCYNUM'   'Agency No.'.
  _add_fcat2 'AGENCYNAME'  'STRAVELAG' 'NAME'      'Agency Name'.

  _add_fcat2 'MENUNUMBER'  'SMENU'   'MENUNUMBER'  'Menu'.

  _add_fcat2 'REQTS'       'ZTMENUREQ_G07' 'REQTS' 'Req Status'.
  _add_fcat2 'REQTS_TXT'   ''              ''      'Request Text'.

  _add_fcat2 'BTN_TXT'     ''              ''      'Action'.

ENDFORM.
