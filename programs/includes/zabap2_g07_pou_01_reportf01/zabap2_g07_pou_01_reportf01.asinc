*&---------------------------------------------------------------------*
*& Form show_reqest
*&---------------------------------------------------------------------*
*& text
*&---------------------------------------------------------------------*
*& -->  p1        text
*& <--  p2        text
*&---------------------------------------------------------------------*
FORM show_reqest .
  DATA: lt_rows TYPE lvc_t_row,
        ls_row  TYPE lvc_s_row,

        ls_data TYPE ty_list2.

  CLEAR: lt_rows, ls_row.

  CALL METHOD go_alv2->get_selected_rows
    IMPORTING
      et_index_rows = lt_rows.

  IF lt_rows IS INITIAL.
    MESSAGE '데이터를 선택하여 주세요!' TYPE 'I' .
    RETURN.
  ELSE.
    READ TABLE lt_rows INTO ls_row INDEX 1.

    READ TABLE gt_data2 INTO ls_data  INDEX ls_row-index.

    IF sy-subrc = 0.
      gv_carrid300 = ls_data-carrid.
      gv_carrnm300 = ls_data-carrname.

      CALL SCREEN 300.
    ENDIF.

  ENDIF.

ENDFORM.
*&---------------------------------------------------------------------*
*& Form get_data_300
*&---------------------------------------------------------------------*
*& text
*&---------------------------------------------------------------------*
*&      --> LV_CARRID
*&      --> LV_MENU_NO
*&---------------------------------------------------------------------*
FORM get_data_300  USING    p_carrid.

  SELECT smn~carrid AS carrid,
         smn~menunumber AS menu,

         smn~starter AS meal1,
         sml1~text AS meal1txt,

         smn~maincourse AS meal2,
         sml2~text AS meal2txt,

         smn~dessert AS meal3,
         sml3~text AS meal3txt

    FROM smenu AS smn JOIN smealt AS sml1 ON smn~starter = sml1~mealnumber
                                         AND smn~carrid  = sml1~carrid
                                         AND sml1~sprache = '3'
                      JOIN smealt AS sml2 ON smn~maincourse = sml2~mealnumber
                                         AND smn~carrid  = sml2~carrid
                                         AND sml2~sprache = '3'
                      JOIN smealt AS sml3 ON smn~dessert = sml3~mealnumber
                                         AND smn~carrid  = sml3~carrid
                                         AND sml3~sprache = '3'
   WHERE smn~carrid = @p_carrid
    INTO CORRESPONDING FIELDS OF TABLE @gt_data3.

*  cl_demo_output=>display( gt_data3 ).

ENDFORM.
*&---------------------------------------------------------------------*
*& Form save_reqest
*&---------------------------------------------------------------------*
*& text
*&---------------------------------------------------------------------*
*& -->  p1        text
*& <--  p2        text
*&---------------------------------------------------------------------*
FORM save_reqest .
  DATA: lt_rows TYPE lvc_t_row,
        ls_row  TYPE lvc_s_row,
        ls_data TYPE ty_list3,
        ls_req  TYPE ztmenureq_g07,
        lv_msg  TYPE char20.

  CALL METHOD go_alv3->get_selected_rows
    IMPORTING
      et_index_rows = lt_rows.

  IF lines( lt_rows ) = 0.
    MESSAGE '데이터를 선택하여 주세요' TYPE 'I' DISPLAY LIKE 'E'.
    RETURN.
  ENDIF.

  READ TABLE lt_rows INTO ls_row INDEX 1.
  READ TABLE gt_data3 INTO ls_data INDEX ls_row-index.

  IF sy-subrc <> 0.
    MESSAGE '데이터를 선택하여 주세요!' TYPE 'I'.
    RETURN.
  ENDIF.

  SELECT SINGLE *
    FROM ztmenureq_g07
    INTO ls_req
   WHERE bookid = zspou01_g07_300-bookid.

  IF sy-subrc = 0.
    IF ls_req-menunumber = ls_data-menu.
      MESSAGE '다른 메뉴를 선택하여 주세요!' TYPE 'I' .
      RETURN.
    ENDIF.
    lv_msg = '변경 신청'.
  ELSE.
    CLEAR ls_req.
    ls_req-bookid = zspou01_g07_300-bookid.
    lv_msg = '신청'.
  ENDIF.

  MOVE-CORRESPONDING zspou01_g07_300 TO ls_req.

  ls_req-menunumber = ls_data-menu.
  ls_req-reqdat     = sy-datum.
  ls_req-reqts      = 'R'.

  MODIFY ztmenureq_g07 FROM ls_req.

  IF sy-subrc = 0.
    COMMIT WORK.
    MESSAGE '기내식 ' && lv_msg && '이 완료되었습니다.' TYPE 'S'.

    zspou01_g07_300-reqdat = sy-datum.
    zspou01_g07_300-menu = ls_data-menu.
  ELSE.
    ROLLBACK WORK.
    MESSAGE '저장 중 오류가 발생했습니다.' TYPE 'E'.
  ENDIF.

ENDFORM.
*&---------------------------------------------------------------------*
*& Form set_screen_300
*&---------------------------------------------------------------------*
*& text
*&---------------------------------------------------------------------*
*& -->  p1        text
*& <--  p2        text
*&---------------------------------------------------------------------*
FORM set_screen_300 .
  DATA: lt_rows   TYPE lvc_t_row,
        ls_row    TYPE lvc_s_row,

        ls_data   TYPE ty_list2,
        lv_carrid TYPE ty_list2-carrid.

  CLEAR: lt_rows, ls_row.

  CALL METHOD go_alv2->get_selected_rows
    IMPORTING
      et_index_rows = lt_rows.

  IF lt_rows IS INITIAL.
    MESSAGE '데이터를 선택하여 주세요!' TYPE 'I' .
    RETURN.
  ELSE.
    READ TABLE lt_rows INTO ls_row INDEX 1.

    READ TABLE gt_data2 INTO ls_data  INDEX ls_row-index.

    IF sy-subrc = 0.
      lv_carrid = ls_data-carrid.

      MOVE-CORRESPONDING ls_data TO zspou01_g07_300.

      zspou01_g07_300-menu = ls_data-menunumber.
      zspou01_g07_300-reqdat = sy-datum.
    ENDIF.

  ENDIF.
ENDFORM.
*&---------------------------------------------------------------------*
*& Form create_cont3
*&---------------------------------------------------------------------*
*& text
*&---------------------------------------------------------------------*
*& -->  p1        text
*& <--  p2        text
*&---------------------------------------------------------------------*
FORM create_cont3 .
  CREATE OBJECT go_cont3
    EXPORTING
      container_name              = 'AREA3'
    EXCEPTIONS
      cntl_error                  = 1
      cntl_system_error           = 2
      create_error                = 3
      lifetime_error              = 4
      lifetime_dynpro_dynpro_link = 5
      OTHERS                      = 6.

  IF sy-subrc <> 0.

  ENDIF.

  CREATE OBJECT go_alv3
    EXPORTING
      i_parent          = go_cont3
    EXCEPTIONS
      error_cntl_create = 1
      error_cntl_init   = 2
      error_cntl_link   = 3
      error_dp_create   = 4
      OTHERS            = 5.

  IF sy-subrc <> 0.

  ENDIF.

  PERFORM set_fcat3.
  PERFORM set_layout3.
  PERFORM set_exclude_toolbar.

  SET HANDLER lcl_event_handler=>on_toolbar      FOR go_alv3.
  SET HANDLER lcl_event_handler=>on_user_command FOR go_alv3.

  CALL METHOD go_alv3->set_table_for_first_display
    EXPORTING
      is_layout                     = gs_layout3
      it_toolbar_excluding          = gt_uiexclude
    CHANGING
      it_outtab                     = gt_data3
      it_fieldcatalog               = gt_fcat3
    EXCEPTIONS
      invalid_parameter_combination = 1
      program_error                 = 2
      too_many_lines                = 3
      OTHERS                        = 4.
  IF sy-subrc <> 0.
*     Implement suitable error handling here
  ENDIF.
ENDFORM.
