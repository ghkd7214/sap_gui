*   Implement suitable error handling here
  ENDIF.
ENDFORM.
*&---------------------------------------------------------------------*
*& Form set_fcat1
*&---------------------------------------------------------------------*
*& text
*&---------------------------------------------------------------------*
*& -->  p1        text
*& <--  p2        text
*&---------------------------------------------------------------------*
FORM set_fcat1 .
  CLEAR gs_fcat1.
  gs_fcat1-fieldname = 'LIGHT'.
  gs_fcat1-coltext   = 'Status'.
  APPEND gs_fcat1 TO gt_fcat1.

  CLEAR gs_fcat1.
  gs_fcat1-fieldname = 'CUST_TXT'.
  gs_fcat1-coltext   = 'Cust. Grade'.
  APPEND gs_fcat1 TO gt_fcat1.

  CLEAR gs_fcat1.
  gs_fcat1-fieldname = 'CUS_ID'.
  gs_fcat1-coltext   = 'Cust. no.'.
  gs_fcat1-ref_table = 'SCUSTOM'.
  gs_fcat1-ref_field = 'ID'.
  APPEND gs_fcat1 TO gt_fcat1.

  CLEAR gs_fcat1.
  gs_fcat1-fieldname = 'CUS_NAME'.
  gs_fcat1-coltext   = 'Customer Name'.
  gs_fcat1-ref_table = 'SCUSTOM'.
  gs_fcat1-ref_field = 'NAME'.
  APPEND gs_fcat1 TO gt_fcat1.

  CLEAR gs_fcat1.
  gs_fcat1-fieldname = 'BP_TYPE'.
  gs_fcat1-coltext   = 'B/P Customer'.
  gs_fcat1-ref_table = 'SCUSTOM'.
  gs_fcat1-ref_field = 'CUSTTYPE'.
  APPEND gs_fcat1 TO gt_fcat1.

  CLEAR gs_fcat1.
  gs_fcat1-fieldname = 'BP_TXT'.
  gs_fcat1-coltext   = 'B/P Customer'.
  APPEND gs_fcat1 TO gt_fcat1.

  CLEAR gs_fcat1.
  gs_fcat1-fieldname = 'BOOK_CNT'.
  gs_fcat1-coltext   = 'Booking Counter'.
  gs_fcat1-do_sum    = 'X'.
  gs_fcat1-inttype   = 'I'.
  APPEND gs_fcat1 TO gt_fcat1.

  CLEAR gs_fcat1.
  gs_fcat1-fieldname = 'POSTCODE'.
  gs_fcat1-coltext   = 'Post. Code'.
  gs_fcat1-ref_table = 'SCUSTOM'.
  gs_fcat1-ref_field = 'POSTCODE'.
  APPEND gs_fcat1 TO gt_fcat1.

  CLEAR gs_fcat1.
  gs_fcat1-fieldname = 'STREET'.
  gs_fcat1-coltext   = 'Street'.
  gs_fcat1-ref_table = 'SCUSTOM'.
  gs_fcat1-ref_field = 'STREET'.
  APPEND gs_fcat1 TO gt_fcat1.

  CLEAR gs_fcat1.
  gs_fcat1-fieldname = 'CITY'.
  gs_fcat1-coltext   = 'City'.
  gs_fcat1-ref_table = 'SCUSTOM'.
  gs_fcat1-ref_field = 'CITY'.
  APPEND gs_fcat1 TO gt_fcat1.

  CLEAR gs_fcat1.
  gs_fcat1-fieldname = 'DISCOUNT'.
  gs_fcat1-coltext   = 'Discount'.
  gs_fcat1-ref_table = 'SCUSTOM'.
  gs_fcat1-ref_field = 'DISCOUNT'.
  APPEND gs_fcat1 TO gt_fcat1.

  CLEAR gs_fcat1.
  gs_fcat1-fieldname = 'TELEPHONE'.
  gs_fcat1-coltext   = 'Telephone No.'.
  gs_fcat1-ref_table = 'SCUSTOM'.
  gs_fcat1-ref_field = 'TELEPHONE'.
  APPEND gs_fcat1 TO gt_fcat1.

  CLEAR gs_fcat1.
  gs_fcat1-fieldname = 'EMAIL'.
  gs_fcat1-coltext   = 'E-Mail Address'.
  gs_fcat1-ref_table = 'SCUSTOM'.
  gs_fcat1-ref_field = 'EMAIL'.
  APPEND gs_fcat1 TO gt_fcat1.

ENDFORM.
