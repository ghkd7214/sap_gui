*&---------------------------------------------------------------------*
*& Form showbooklist_100
*&---------------------------------------------------------------------*
*& text
*&---------------------------------------------------------------------*
*& -->  p1        text
*& <--  p2        text
*&---------------------------------------------------------------------*
FORM showbooklist_100 .
  DATA: lt_rows  TYPE lvc_t_row,
        ls_row   TYPE lvc_s_row,

        ls_data1 TYPE ty_list1.


  CLEAR: lt_rows, ls_row.

  CALL METHOD go_alv->get_selected_rows
    IMPORTING
      et_index_rows = lt_rows.

  IF lt_rows IS INITIAL.
    MESSAGE '데이터를 선택해주세요!' TYPE 'I' .
    RETURN.
  ELSE.
    READ TABLE lt_rows INTO ls_row INDEX 1.
    READ TABLE gt_data1 INTO ls_data1 INDEX ls_row-index.

    IF sy-subrc = 0.
      gv_custid200 = ls_data1-cus_id.
      gv_bookid200 = ls_data1-cus_id.
      gv_booknm200 = ls_data1-cus_name.

      CALL SCREEN 200.
    ENDIF.

  ENDIF.

ENDFORM.
*&---------------------------------------------------------------------*
*& Form get_data_200
*&---------------------------------------------------------------------*
*& text
*&---------------------------------------------------------------------*
*&      --> LV_CUSTOMID
*&---------------------------------------------------------------------*
FORM get_data_200  USING    p_customid.
  DATA: lr_class TYPE RANGE OF sbook-class,
        ls_class LIKE LINE OF lr_class,

        lr_bp    TYPE RANGE OF scustom-custtype,
        ls_bp    LIKE LINE OF lr_bp.

  CLEAR ls_class.
  IF r_all <> 'X'.
    ls_class-sign = 'I'.
    ls_class-option = 'EQ'.

    CASE 'X'.
      WHEN r_eco.
        ls_class-low = 'C'.
      WHEN r_bus.
        ls_class-low = 'B'.
      WHEN r_fir.
        ls_class-low = 'F'.
    ENDCASE.
    APPEND ls_class TO lr_class.
  ENDIF.

  CLEAR ls_bp.
  IF  pa_ctype IS NOT INITIAL.
    ls_bp-sign   = 'I'.
    ls_bp-option = 'EQ'.
    ls_bp-low    = pa_ctype.
    APPEND ls_bp TO lr_bp.
  ENDIF.

  CLEAR gt_data2.

  SELECT sb~carrid,
         sc~carrname,
         sb~connid,
         sb~fldate,
         sb~bookid,
         sb~customid,
         sb~custtype,
         sb~smoker,
         sb~luggweight,
         sb~wunit,
         sb~class,
         sb~loccuram,
         sb~loccurkey,
         sb~order_date,
         sb~counter,
         sb~agencynum,
         st~name AS agencyname,
         ztm~menunumber,
         ztm~reqts,

         CASE ztm~reqts
           WHEN 'R' THEN 'Requested'
           WHEN 'N' THEN 'Not Requested'
           WHEN 'C' THEN 'Cancel'
         ELSE ' '
         END AS reqts_txt,

         CASE ztm~reqts
           WHEN 'R' THEN '3'
           WHEN 'C' THEN '1'
           ELSE ' '
         END AS light

    FROM sbook AS sb JOIN scarr AS sc ON sb~carrid = sc~carrid
                     JOIN stravelag AS st ON sb~agencynum = st~agencynum
                     JOIN scustom AS scu ON sb~customid = scu~id
                     LEFT OUTER JOIN ztmenureq_g07 AS ztm ON sb~bookid = ztm~bookid

    WHERE sb~customid = @p_customid
      AND sb~fldate   IN @so_fld
      AND scu~custtype IN @lr_bp
      AND sb~class    IN @lr_class
      AND sb~cancelled <> 'X'
      AND sb~agencynum <> '00000000'

    INTO CORRESPONDING FIELDS OF TABLE @gt_data2.

  DATA: ls_style TYPE lvc_s_styl.

  LOOP AT gt_data2 INTO gs_data2.
    CLEAR: gs_data2-row_col,
           gs_data2-btn_txt,
           gs_data2-btn_cel.

    IF gs_data2-menunumber IS INITIAL.
      gs_data2-reqts = 'N'.
    ENDIF.

    CASE gs_data2-reqts.
      WHEN 'C'. " Cancel
        gs_data2-row_col = 'C610'. " Red
      WHEN 'N' OR ' '.
        gs_data2-row_col = 'C310'. " Yellow
    ENDCASE.

    IF gs_data2-reqts = 'R'.
      gs_data2-btn_txt = 'Cancel'.
      ls_style-fieldname = 'BTN_TXT'.                 " 버튼으로 만들 필드명
      ls_style-style     = cl_gui_alv_grid=>mc_style_button. " 스타일 상수

      INSERT ls_style INTO TABLE gs_data2-btn_cel.
    ENDIF.

    MODIFY gt_data2 FROM gs_data2.
  ENDLOOP.
ENDFORM.
*&---------------------------------------------------------------------*
*& Form create_cont2
*&---------------------------------------------------------------------*
*& text
*&---------------------------------------------------------------------*
*& -->  p1        text
