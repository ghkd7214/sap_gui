*&---------------------------------------------------------------------*
*& Form open_popup_tab
*&---------------------------------------------------------------------*
*& text
*&---------------------------------------------------------------------*
*&      --> LS_DATA
*&---------------------------------------------------------------------*
FORM open_popup_tab  USING    ps_data TYPE ty_list2.
  CLEAR: zspou01_g07_401, zspou01_g07_402.

  SELECT SINGLE
         carrid,
         connid,
         fltime,
         distance,
         distid,
         fltype,
         countryfr,
         cityfrom,
         airpfrom,
         deptime,
         countryto,
         cityto,
         airpto,
         arrtime,
         sa1~name AS fname,
         sa2~name AS tname
    FROM spfli AS sp JOIN sairport AS sa1 ON sp~airpfrom = sa1~id
                     JOIN sairport AS sa2 ON sp~airpfrom = sa2~id
    INTO CORRESPONDING FIELDS OF @zspou01_g07_401
    WHERE carrid = @gs_data2-carrid
      AND connid = @gs_data2-connid.

  IF zspou01_g07_401-fltype = 'X'.
    cb401_s = 'X'.
  ELSE.
    cb401_c = 'X'.
  ENDIF.

  SELECT SINGLE
         carrid
         connid
         fldate
         price
         currency
         paymentsum
         planetype
         seatsmax
         seatsmax_b
         seatsmax_f
         seatsocc
         seatsocc_b
         seatsocc_f
    FROM sflight
    INTO CORRESPONDING FIELDS OF zspou01_g07_402
    WHERE carrid = gs_data2-carrid
      AND connid = gs_data2-connid
      AND fldate = gs_data2-fldate.

  zspou01_g07_402-tmax = zspou01_g07_402-seatsmax + zspou01_g07_402-seatsmax_b + zspou01_g07_402-seatsmax_f.
  zspou01_g07_402-tocc = zspou01_g07_402-seatsocc + zspou01_g07_402-seatsocc_b + zspou01_g07_402-seatsocc_f.
  zspou01_g07_402-freeseats = zspou01_g07_402-tmax - zspou01_g07_402-tocc.
  zspou01_g07_402-booking_rate = zspou01_g07_402-tocc * 100 / zspou01_g07_402-tmax.

  CALL SCREEN 400 STARTING AT 10 5.

ENDFORM.
*&---------------------------------------------------------------------*
*& Module STATUS_0400 OUTPUT
*&---------------------------------------------------------------------*
*&
*&---------------------------------------------------------------------*
MODULE status_0400 OUTPUT.
  SET TITLEBAR 'T400'.
  SET PF-STATUS 'S400'.

  CASE ts_info-activetab.
    WHEN 'TAB1'.
      gv_subsc = '0401'.
    WHEN 'TAB2'.
      gv_subsc = '0402'.
    WHEN OTHERS.
      ts_info-activetab = 'TAB1'.
      gv_subsc = '0401'.
  ENDCASE.
ENDMODULE.
*&---------------------------------------------------------------------*
*&      Module  USER_COMMAND_0400  INPUT
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
MODULE user_command_0400 INPUT.
  CASE ok_code.
    WHEN 'TAB1' OR 'TAB2' .
      ts_info-activetab = ok_code.
*    WHEN 'CLOSE' OR 'CANC' or 'BACK' or 'CANCEl'. " 팝업 닫기
*      LEAVE TO SCREEN 0.
    WHEN 'BACK' OR 'CANCEl'.
      LEAVE TO SCREEN 0.
    WHEN 'EXIT'.
      LEAVE PROGRAM.
  ENDCASE.
ENDMODULE.
*&---------------------------------------------------------------------*
*& Form open_popup_meal
*&---------------------------------------------------------------------*
*& text
*&---------------------------------------------------------------------*
*&      --> LS_DATA
*&---------------------------------------------------------------------*
FORM open_popup_meal  USING    p_data TYPE ty_list2.
  IF p_data-menunumber = '' .
    MESSAGE '메뉴 지정후 이용해주십시오.' TYPE 'S' .
    RETURN.
  ENDIF.
  SELECT SINGLE
         smn~carrid AS carrid,
         sc~carrname AS name,
         smn~menunumber AS menu,

         smn~starter AS starter,
         sml1~text AS text1,

         smn~maincourse AS maincourse,
         sml2~text AS text2,

         smn~dessert AS dessert,
         sml3~text AS text3

    FROM smenu AS smn JOIN smealt AS sml1 ON smn~starter = sml1~mealnumber
                                         AND smn~carrid  = sml1~carrid
                                         AND sml1~sprache = '3'
                      JOIN smealt AS sml2 ON smn~maincourse = sml2~mealnumber
                                         AND smn~carrid  = sml2~carrid
                                         AND sml2~sprache = '3'
                      JOIN smealt AS sml3 ON smn~dessert = sml3~mealnumber
                                         AND smn~carrid  = sml3~carrid
                                         AND sml3~sprache = '3'
                      JOIN scarr AS sc ON smn~carrid = sc~carrid
   WHERE smn~carrid = @p_data-carrid
     AND smn~menunumber = @p_data-menunumber
    INTO CORRESPONDING FIELDS OF @zspou01_g07_403.

  CALL SCREEN 403 STARTING AT 10 5.

ENDFORM.