*&---------------------------------------------------------------------*
*& Include          ZABAP2_G07_POU_01_REPORTPBO
*&---------------------------------------------------------------------*
*&---------------------------------------------------------------------*
*& Module STATUS_0100 OUTPUT
*&---------------------------------------------------------------------*
*&
*&---------------------------------------------------------------------*
MODULE status_0100 OUTPUT.
  SET PF-STATUS 'S100'.
  SET TITLEBAR 'T100' WITH gv_data1_cnt.
ENDMODULE.
*&---------------------------------------------------------------------*
*& Module INIT_100 OUTPUT
*&---------------------------------------------------------------------*
*&
*&---------------------------------------------------------------------*
MODULE init_100 OUTPUT.

  IF go_cont IS INITIAL.
    PERFORM create_cont.
  ELSE.
    PERFORM refresh_grid.
  ENDIF.

ENDMODULE.
*&---------------------------------------------------------------------*
*& Module STATUS_0200 OUTPUT
*&---------------------------------------------------------------------*
*&
*&---------------------------------------------------------------------*
MODULE status_0200 OUTPUT.
  SET PF-STATUS 'S200'.
  SET TITLEBAR 'T200' with gv_bookid200 gv_booknm200.
ENDMODULE.
*&---------------------------------------------------------------------*
*& Module CLEAR_OK_CODE OUTPUT
*&---------------------------------------------------------------------*
*&
*&---------------------------------------------------------------------*
MODULE clear_ok_code OUTPUT.
  CLEAR ok_code.
ENDMODULE.
*&---------------------------------------------------------------------*
*& Module INIT_200 OUTPUT
*&---------------------------------------------------------------------*
*&
*&---------------------------------------------------------------------*
MODULE init_200 OUTPUT.
  IF go_cont2 IS INITIAL.
    PERFORM create_cont2.
  ELSE.
    PERFORM refresh_grid2.
  ENDIF.
ENDMODULE.
*&---------------------------------------------------------------------*
*& Module STATUS_0300 OUTPUT
*&---------------------------------------------------------------------*
*&
*&---------------------------------------------------------------------*
MODULE status_0300 OUTPUT.
  SET PF-STATUS 'S300'.
  SET TITLEBAR 'T300' with gv_carrid300 gv_carrnm300.
ENDMODULE.
*&---------------------------------------------------------------------*
*& Module INIT_300 OUTPUT
*&---------------------------------------------------------------------*
*&
*&---------------------------------------------------------------------*
MODULE init_300 OUTPUT.

  PERFORM set_screen_300.

  IF go_cont3 IS INITIAL.
    PERFORM create_cont3.
  ELSE.
    PERFORM refresh_grid3.
  ENDIF.
ENDMODULE.
*&---------------------------------------------------------------------*
*& Module GET_DATA_200 OUTPUT
*&---------------------------------------------------------------------*
*&
*&---------------------------------------------------------------------*
MODULE get_data_200 OUTPUT.
  PERFORM get_data_200 USING gv_custid200.
ENDMODULE.
*&---------------------------------------------------------------------*
*& Module GET_DATA_300 OUTPUT
*&---------------------------------------------------------------------*
*&
*&---------------------------------------------------------------------*
MODULE get_data_300 OUTPUT.
  PERFORM get_data_300 USING gv_carrid300.
ENDMODULE.