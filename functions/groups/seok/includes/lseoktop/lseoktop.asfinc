function-pool seok
  message-id oo.

include:
  lseokerr,
  lseokmac,
  lseoklog.

type-pools:
  seos,
  seor,
  seoa,
  seof,
  seot,
  seok,
  seop,
  tpchk,
  seoe,
  seod.

class cl_oo_include_naming definition load.
class cl_oo_classname_service definition load.
class cl_oo_class_modifications definition load.
class cl_oo_interface_modifications definition load.

* buffer tables
