xbuffer param.                                              "#EC NEEDED
xbuffer excep.                                              "#EC NEEDED
buffer compri.                                              "#EC NEEDED
buffer implem.                                              "#EC NEEDED
buffer extend.                                              "#EC NEEDED
taddition redef seorelkey.                                  "#EC NEEDED
buffer compos.                                              "#EC NEEDED
